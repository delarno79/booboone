# ============================================================
#  Booboone Auto-Blog — Configuration
#  Copy this file to ".env" and fill in the values.
#  You can change any of these later without touching the code.
# ============================================================

# --- WordPress ---------------------------------------------
# The site URL (no trailing slash).
WP_URL=https://booboone.com
# Your WordPress username.
WP_USER=your_wordpress_username
# An "Application Password" (WP Admin -> Users -> Profile -> Application Passwords).
# NOT your normal login password.
WP_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx

# --- AI: Text (DeepSeek) -----------------------------------
DEEPSEEK_API_KEY=your_deepseek_key
DEEPSEEK_MODEL=deepseek-chat

# --- Images ------------------------------------------------
# How featured images are sourced:
#   free_ai -> FREE AI-generated images (Pollinations), stock fallback  [recommended]
#   stock   -> free stock photos only (Openverse)
#   auto    -> paid Gemini/Imagen -> free AI -> stock
#   ai      -> paid Gemini/Imagen only (needs billing on the Google account)
#   none    -> no featured images
# NOTE: Google's Gemini/Imagen image API is PAID-ONLY (free tier = 0 image quota),
# so "free_ai" is the way to get AI images without any billing.
IMAGE_SOURCE=free_ai
# GEMINI_API_KEY + IMAGE_MODEL are only used for IMAGE_SOURCE=ai/auto (needs billing).
GEMINI_API_KEY=your_gemini_key
IMAGE_MODEL=gemini-2.5-flash-image

# --- Behaviour (safe defaults, change any time) ------------
# publish  -> posts go live immediately
# draft    -> posts are saved as drafts for review first
POST_STATUS=publish

# Max posts to create per run (one per category by default).
# Leave blank to do exactly one per category each run.
MAX_POSTS_PER_RUN=

# Set to "true" to generate featured images, "false" to skip them.
GENERATE_IMAGES=true

# Author id for the posts (optional; leave blank to use the token owner).
POST_AUTHOR_ID=
